{
  "name": "vite_react_shadcn_ts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:watch": "node scripts/auto-build.js",
    "build:dev": "vite build --mode development",
    "build:auto": "node scripts/auto-build.js",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "preview": "vite preview",
    "test": "vitest",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:codegen": "playwright codegen",
    "test:e2e:staging": "playwright test --config playwright.staging.config.ts",
    "test:e2e:production": "playwright test --config playwright.production.config.ts",
    "test:smoke": "playwright test --config playwright.smoke.config.ts",
    "test:performance": "playwright test --config playwright.performance.config.ts",
    "test:security": "playwright test --config playwright.security.config.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "type-check": "tsc --noEmit",
    "prepare": "husky install",
    "pre-commit": "lint-staged",
    "commit-cz": "git-cz",
    "deploy:staging": "./scripts/deploy.sh staging",
    "deploy:production": "./scripts/deploy.sh production",
    "deploy:rollback": "./scripts/deploy.sh rollback",
    "health:check": "./scripts/health-check.sh full",
    "health:application": "./scripts/health-check.sh application",
    "health:apis": "./scripts/health-check.sh apis",
    "health:database": "./scripts/health-check.sh database",
    "health:system": "./scripts/health-check.sh system",
    "docker:build": "docker build -t cinecasa/app .",
    "docker:run": "docker run -p 3000:8080 cinecasa/app",
    "docker:compose": "docker-compose up -d",
    "docker:compose:down": "docker-compose down",
    "docker:compose:logs": "docker-compose logs -f",
    "k8s:deploy": "kubectl apply -f k8s/",
    "k8s:status": "kubectl get pods -n production",
    "k8s:logs": "kubectl logs -f deployment/cinecasa -n production",
    "k8s:rollback": "kubectl rollout undo deployment/cinecasa -n production",
    "monitor:metrics": "curl -s http://localhost:9090/metrics",
    "monitor:grafana": "open http://localhost:3003",
    "security:audit": "npm audit --audit-level=moderate",
    "security:fix": "npm audit fix",
    "backup:create": "./scripts/backup.sh create",
    "backup:restore": "./scripts/backup.sh restore",
    "cleanup:docker": "docker system prune -f",
    "cleanup:logs": "find ./logs -name \"*.log\" -mtime +7 -delete",
    "analyze:bundle": "npx vite-bundle-analyzer dist",
    "analyze:performance": "npx lighthouse http://localhost:3000 --output=json --output-path=./lighthouse-report.json",
    "validate:env": "node scripts/validate-env.js",
    "prepare:release": "npm run test && npm run build && npm run security:audit",
    "release": "semantic-release",
    "precommit": "npm run lint && npm run type-check && npm run test:unit",
    "prepush": "npm run test:integration",
    "start": "vite --port 3000 --host 0.0.0.0",
    "commit": "./scripts/auto-commit.sh",
    "commit:all": "./scripts/auto-commit.sh \"feat: atualização automática\"",
    "push": "git push origin main",
    "sync": "git pull origin main && git add . && git commit -m \"sync: atualização automática\" && git push origin main"
  },
  "dependencies": {
    "@clappr/core": "^0.13.2",
    "@clappr/plugins": "^0.8.11",
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-context-menu": "^2.2.15",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-hover-card": "^1.1.14",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.15",
    "@radix-ui/react-navigation-menu": "^1.2.13",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toast": "^1.2.14",
    "@radix-ui/react-toggle": "^1.1.9",
    "@radix-ui/react-toggle-group": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@supabase/supabase-js": "^2.98.0",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tanstack/react-query": "^5.83.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^3.6.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.34.2",
    "hls.js": "^1.6.15",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.462.0",
    "next-themes": "^0.3.0",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.61.1",
    "react-resizable-panels": "^2.1.9",
    "react-router-dom": "^6.30.1",
    "recharts": "^2.15.4",
    "shaka-player": "^5.0.8",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^0.9.9",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.16.5",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "autoprefixer": "^10.4.21",
    "commitizen": "^4.3.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-playwright": "^0.19.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "eslint-plugin-testing-library": "^6.2.0",
    "globals": "^15.15.0",
    "husky": "^8.0.3",
    "jsdom": "^28.1.0",
    "lint-staged": "^15.2.0",
    "lovable-tagger": "^1.1.13",
    "msw": "^2.0.11",
    "postcss": "^8.5.6",
    "prettier": "^3.1.1",
    "sharp": "^0.34.5",
    "storybook": "^7.6.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vite": "^7.3.2",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "vitest related --run"
    ],
    "*.{css,scss}": [
      "prettier --write"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
