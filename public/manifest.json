{
  "name": "CineCasa - Entretenimento e Lazer",
  "short_name": "CineCasa",
  "description": "O melhor do entretenimento para você e sua família. Filmes, séries e conteúdo exclusivo.",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#000000",
  "theme_color": "#000000",
  "splash_pages": null,
  "launch_handler": {
    "client_mode": ["navigate-existing", "auto"]
  },
  "orientation": "portrait",
  "scope": "/",
  "lang": "pt-BR",
  "dir": "ltr",
  "categories": ["entertainment", "movies", "streaming", "video"],
  "screenshots": [
    {
      "src": "/screenshots/home-wide.png",
      "sizes": "1920x1080",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Tela inicial do CineCasa"
    },
    {
      "src": "/screenshots/home-narrow.png",
      "sizes": "750x1334",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "CineCasa no mobile"
    }
  ],
  "icons": [
    {
      "src": "/logo.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/favicon.ico",
      "sizes": "48x48",
      "type": "image/x-icon"
    }
  ],
  "shortcuts": [
    {
      "name": "Continuar Assistindo",
      "short_name": "Continuar",
      "description": "Retomar o último conteúdo assistido",
      "url": "/continue-watching",
      "icons": [{ "src": "/logo.png", "sizes": "512x512" }]
    },
    {
      "name": "Filmes",
      "short_name": "Filmes",
      "description": "Ver filmes disponíveis",
      "url": "/cinema",
      "icons": [{ "src": "/logo.png", "sizes": "512x512" }]
    },
    {
      "name": "Séries",
      "short_name": "Séries",
      "description": "Ver séries disponíveis",
      "url": "/series",
      "icons": [{ "src": "/logo.png", "sizes": "512x512" }]
    },
    {
      "name": "Favoritos",
      "short_name": "Favoritos",
      "description": "Ver meus favoritos",
      "url": "/favorites",
      "icons": [{ "src": "/logo.png", "sizes": "512x512" }]
    },
    {
      "name": "Busca Rápida",
      "short_name": "Buscar",
      "description": "Buscar filmes e séries",
      "url": "/search",
      "icons": [{ "src": "/logo.png", "sizes": "512x512" }]
    },
    {
      "name": "Novidades",
      "short_name": "Novos",
      "description": "Ver novos lançamentos",
      "url": "/new-releases",
      "icons": [{ "src": "/logo.png", "sizes": "512x512" }]
    }
  ],
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.cinecasa.app",
      "id": "com.cinecasa.app"
    },
    {
      "platform": "itunes",
      "url": "https://apps.apple.com/app/cinecasa/id1234567890"
    }
  ],
  "prefer_related_applications": false,
  "protocol_handlers": [
    {
      "protocol": "web+cinecasa",
      "url": "/watch?title=%s"
    }
  ],
  "share_target": {
    "action": "/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "name",
      "text": "description",
      "url": "link"
    }
  }
}
