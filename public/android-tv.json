{
  "packageName": "com.cinecasa.app",
  "versionCode": 1,
  "versionName": "1.0.0",
  "minSdkVersion": 21,
  "targetSdkVersion": 34,
  "compileSdkVersion": 34,
  "application": {
    "label": "@string/app_name",
    "icon": "@mipmap/ic_launcher",
    "roundIcon": "@mipmap/ic_launcher_round",
    "banner": "@drawable/banner",
    "theme": "@style/Theme.CineCasa",
    "usesCleartextTraffic": false,
    "supportsRtl": true,
    "allowBackup": true,
    "fullBackupContent": true,
    "networkSecurityConfig": "@xml/network_security_config",
    "leanback": {
      "enabled": true,
      "banner": "@drawable/leanback_banner",
      "icon": "@drawable/leanback_icon",
      "splash": "@drawable/leanback_splash"
    },
    "features": [
      "android.software.leanback",
      "android.hardware.touchscreen",
      "android.hardware.faketouch",
      "android.hardware.television"
    ],
    "permissions": [
      "android.permission.INTERNET",
      "android.permission.ACCESS_NETWORK_STATE",
      "android.permission.WAKE_LOCK",
      "android.permission.FOREGROUND_SERVICE",
      "com.android.providers.tv.permission.READ_EPG_DATA",
      "com.android.providers.tv.permission.WRITE_EPG_DATA"
    ]
  },
  "tvInputService": {
    "enabled": true,
    "setupActivity": ".tv.TvSetupActivity",
    "inputId": "com.cinecasa.app/.tv.CineCasaTvInputService"
  },
  "leanback": {
    "launcher": {
      "banner": {
        "width": 320,
        "height": 180,
        "dpi": [160, 213, 240, 320, 480, 640]
      },
      "icon": {
        "width": 192,
        "height": 192,
        "dpi": [160, 213, 240, 320, 480, 640]
      }
    },
    "search": {
      "enabled": true,
      "suggestionProvider": ".search.CineCasaSuggestionProvider"
    },
    "recommendations": {
      "enabled": true,
      "notificationChannel": "cinecasa_recommendations"
    }
  },
  "intentFilters": [
    {
      "action": "android.intent.action.MAIN",
      "category": ["android.intent.category.LAUNCHER", "android.intent.category.LEANBACK_LAUNCHER"]
    },
    {
      "action": "android.intent.action.VIEW",
      "category": ["android.intent.category.DEFAULT", "android.intent.category.BROWSABLE"],
      "data": {
        "scheme": "https",
        "host": "cinecasa.com.br",
        "pathPrefix": "/"
      }
    },
    {
      "action": "android.intent.action.SEARCH",
      "category": ["android.intent.category.DEFAULT"]
    }
  ],
  "metaData": {
    "com.google.android.gms.cast.framework.OPTIONS_PROVIDER_CLASS_NAME": "com.cinecasa.cast.CastOptionsProvider",
    "com.google.android.gms.version": "@integer/google_play_services_version",
    "com.android.tv.app": "true"
  }
}
