# Configurações de Deploy - CineCasa
# Copie este arquivo para .env.deploy e preencha com seus valores

# ========================================
# CONFIGURAÇÕES GERAIS
# ========================================
ENVIRONMENT=production
DEPLOY_TARGET=docker
DOMAIN=cinecasa.com.br
COMMIT_SHA=$(git rev-parse HEAD)

# ========================================
# URLS E ENDPOINTS
# ========================================
BASE_URL=https://cinecasa.com.br
STAGING_URL=https://staging.cinecasa.com.br
PRODUCTION_URL=https://cinecasa.com.br

# Health Check URLs
STAGING_HEALTH_CHECK_URL=https://staging.cinecasa.com.br/health
PRODUCTION_HEALTH_CHECK_URL=https://cinecasa.com.br/health
ACTIVE_ENV_CHECK_URL=https://api.cinecasa.com.br/active-env

# API URLs
API_HEALTH_URL=https://api.cinecasa.com.br/health
STAGING_API_URL=https://api-staging.cinecasa.com.br
PRODUCTION_API_URL=https://api.cinecasa.com.br

# ========================================
# SUPABASE CONFIG
# ========================================
SUPABASE_URL=https://api.supabase.com
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ========================================
# BANCO DE DADOS
# ========================================
POSTGRES_DB=cinecasa
POSTGRES_USER=cinecasa
POSTGRES_PASSWORD=your_postgres_password_here
DATABASE_URL=postgresql://cinecasa:your_postgres_password_here@postgres:5432/cinecasa

# ========================================
# REDIS
# ========================================
REDIS_URL=redis://:your_redis_password_here@redis:6379
REDIS_PASSWORD=your_redis_password_here

# ========================================
# JWT E SEGURANÇA
# ========================================
JWT_SECRET=your_jwt_secret_here
CORS_ORIGIN=https://cinecasa.com.br

# ========================================
# IMAGENS DOCKER
# ========================================
IMAGE_NAME=cinecasa/app
REGISTRY=ghcr.io/cinecasa

# ========================================
# PORTAS
# ========================================
APP_PORT=3000
APP_GREEN_PORT=3001
API_PORT=3002
LB_PORT=80
LB_HTTPS_PORT=443
POSTGRES_PORT=5433
REDIS_PORT=6380
PROMETHEUS_PORT=9090
GRAFANA_PORT=3003
ELASTICSEARCH_PORT=9201
KIBANA_PORT=5602

# ========================================
# SSL/TLS
# ========================================
SSL_PORT=443
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# ========================================
# MONITORAMENTO
# ========================================
MONITORING_API_URL=https://monitoring.cinecasa.com.br
TMDB_API_KEY=your_tmdb_api_key_here

# Grafana
GRAFANA_PASSWORD=your_grafana_password_here

# ========================================
# WEBHOOKS E NOTIFICAÇÕES
# ========================================
LOAD_BALANCER_WEBHOOK=https://api.cinecasa.com.br/load-balancer
DEPLOYMENT_STATUS_WEBHOOK=https://api.cinecasa.com.br/deployment-status
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
NOTIFICATION_EMAIL=devops@cinecasa.com.br

# ========================================
# EXTERNAL SERVICES
# ========================================
# TMDB API
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_BASE_URL=https://api.themoviedb.org/3

# Image CDN
IMAGE_CDN_BASE_URL=https://image.tmdb.org/t/p/

# ========================================
# BACKUP
# ========================================
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=cinecasa-backups
BACKUP_S3_REGION=us-east-1

# ========================================
# PERFORMANCE
# ========================================
MAX_RESPONSE_TIME=5
MAX_ERROR_RATE=5
MAX_CPU_USAGE=80
MAX_MEMORY_USAGE=85
MAX_DISK_USAGE=90

# ========================================
# AUTOSCALING
# ========================================
MIN_REPLICAS=3
MAX_REPLICAS=10
TARGET_CPU_UTILIZATION=70
TARGET_MEMORY_UTILIZATION=80

# ========================================
# RATE LIMITING
# ========================================
API_RATE_LIMIT=10
STATIC_RATE_LIMIT=30
UPLOAD_RATE_LIMIT=2

# ========================================
# CACHE
# ========================================
CACHE_TTL_STATIC=1y
CACHE_TTL_API=1h
CACHE_TTL_HTML=1h
CACHE_MAX_SIZE=100MB

# ========================================
# SEGURANÇA
# ========================================
ENABLE_SECURITY_HEADERS=true
ENABLE_CORS=true
ENABLE_RATE_LIMITING=true
ENABLE_WAF=true

# CSP Headers
CSP_DEFAULT_SRC="'self'"
CSP_SCRIPT_SRC="'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com https://www.google-analytics.com"
CSP_STYLE_SRC="'self' 'unsafe-inline' https://fonts.googleapis.com"
CSP_FONT_SRC="'self' https://fonts.gstatic.com"
CSP_IMG_SRC="'self' data: https:"
CSP_CONNECT_SRC="'self' https://api.themoviedb.org https://image.tmdb.org https://*.supabase.co"

# ========================================
# LOGGING
# ========================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_MAX_SIZE=100MB
LOG_MAX_FILES=10

# ========================================
# HEALTH CHECKS
# ========================================
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10
HEALTH_CHECK_RETRIES=3
HEALTH_CHECK_STARTUP_DELAY=40

# Liveness Probe
LIVENESS_PATH=/health
LIVENESS_INITIAL_DELAY=30
LIVENESS_PERIOD=10
LIVENESS_TIMEOUT=5
LIVENESS_FAILURE_THRESHOLD=3

# Readiness Probe
READINESS_PATH=/ready
READINESS_INITIAL_DELAY=5
READINESS_PERIOD=5
READINESS_TIMEOUT=3
READINESS_FAILURE_THRESHOLD=3

# ========================================
# ROLLBACK
# ========================================
ROLLBACK_TIMEOUT=300
ROLLBACK_GRACE_PERIOD=1800
ROLLBACK_NOTIFICATION_ENABLED=true

# ========================================
# BLUE-GREEN DEPLOYMENT
# ========================================
BLUE_GREEN_ENABLED=true
SWITCH_TRAFFIC_DELAY=30
OLD_ENV_CLEANUP_DELAY=1800

# ========================================
# CI/CD
# ========================================
CI_ENABLED=true
CD_ENABLED=true
AUTO_DEPLOY_ON_MERGE=false
REQUIRE_APPROVAL_FOR_PROD=true

# GitHub Actions
GITHUB_TOKEN=your_github_token_here
GITHUB_REPO=cinecasa/cinecasa

# ========================================
# TESTING
# ========================================
ENABLE_SMOKE_TESTS=true
ENABLE_PERFORMANCE_TESTS=true
ENABLE_SECURITY_TESTS=true
TEST_TIMEOUT=300000

# ========================================
# FEATURE FLAGS
# ========================================
ENABLE_NEW_FEATURE_X=false
ENABLE_BETA_FEATURES=false
ENABLE_DEBUG_MODE=false

# ========================================
# MAINTENANCE
# ========================================
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE="Sistema em manutenção. Voltamos em breve."
MAINTENANCE_START_TIME=
MAINTENANCE_END_TIME=

# ========================================
# ANALYTICS
# ========================================
GOOGLE_ANALYTICS_ID=GA_MEASUREMENT_ID
SENTRY_DSN=your_sentry_dsn_here
DATADOG_API_KEY=your_datadog_key_here

# ========================================
# CDN
# ========================================
CDN_ENABLED=true
CDN_PROVIDER=cloudflare
CDN_ZONE_ID=your_cloudflare_zone_id
CDN_API_TOKEN=your_cloudflare_api_token

# ========================================
# DEVELOPMENT
# ========================================
DEBUG_MODE=false
VERBOSE_LOGGING=false
HOT_RELOAD=false
